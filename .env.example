# ──────────────────────────────────────────────
# Database (local PostgreSQL)
# TODO: replace appuser, apppassword and appdb with your project values
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://appuser:apppassword@localhost:5432/appdb"

# ──────────────────────────────────────────────
# App
# TODO: replace with your app name
# ──────────────────────────────────────────────
NUXT_PUBLIC_APP_NAME="Your App Name"
NODE_ENV=development

# ──────────────────────────────────────────────
# Authentication
# TODO: generate a strong secret — e.g. openssl rand -base64 32
# ──────────────────────────────────────────────
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="24h"

# ──────────────────────────────────────────────
# CORS (comma-separated list of allowed origins)
# TODO: set to your frontend URL in production
# ──────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:3000"

# ──────────────────────────────────────────────
# Rate limiting
# TODO: adjust to your needs
# ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ──────────────────────────────────────────────
# App URL (used for health checks and deploy)
# TODO: set to your staging/production URL
# ──────────────────────────────────────────────
APP_URL="http://localhost:3000"
