## PrimeVue UI Standards

### Component Usage

PrimeVue components are auto-imported via `@primevue/nuxt-module`. No manual imports needed.

```vue
<template>
  <!-- Use PrimeVue components directly -->
  <DataTable :value="users" :loading="pending" paginator :rows="10">
    <Column field="name" header="Name" sortable />
    <Column field="email" header="Email" />
    <Column header="Actions">
      <template #body="{ data }">
        <Button icon="pi pi-trash" severity="danger" @click="removeUser(data.id)" />
      </template>
    </Column>
  </DataTable>
</template>
```

Rules:
- Check PrimeVue documentation before writing a custom component — it likely already exists
- Do not install other UI libraries (Bootstrap, Vuetify, etc.) without justification
- Wrap PrimeVue components in `app/components/ui/` only when you need repeated customization

### Form Handling

```vue
<script setup lang="ts">
import { parse, ValiError } from 'valibot'
import { CreateUserSchema } from '~/shared/schemas/userSchemas'

const form = reactive({ name: '', email: '' })
const errors = ref<Record<string, string>>({})
const saving = ref(false)

async function handleSubmit() {
  errors.value = {}
  try {
    const validated = parse(CreateUserSchema, form)
    saving.value = true
    await $fetch('/api/users', { method: 'POST', body: validated })
    navigateTo('/users')
  } catch (error) {
    if (error instanceof ValiError) {
      // Map Valibot issues to field errors
      error.issues.forEach((issue) => {
        if (issue.path) errors.value[issue.path[0].key as string] = issue.message
      })
    }
  } finally {
    saving.value = false
  }
}
</script>

<template>
  <form @submit.prevent="handleSubmit">
    <div class="field">
      <label for="name">Name *</label>
      <InputText id="name" v-model="form.name" :invalid="!!errors.name" />
      <small v-if="errors.name" class="p-error">{{ errors.name }}</small>
    </div>

    <Button type="submit" label="Save" :loading="saving" />
  </form>
</template>
```

### Feedback Patterns

```typescript
// Toast notifications (use PrimeVue's useToast)
const toast = useToast()
toast.add({ severity: 'success', summary: 'Saved', detail: 'User created successfully', life: 3000 })
toast.add({ severity: 'error', summary: 'Error', detail: 'Failed to save user', life: 5000 })

// Confirmation dialog (use PrimeVue's useConfirm)
const confirm = useConfirm()
confirm.require({
  message: 'Are you sure you want to delete this user?',
  header: 'Confirm deletion',
  accept: () => removeUser(id),
})
```

