## Composables

### Data Fetching with useFetch

Prefer `useFetch` / `useAsyncData` for SSR-aware fetching in pages and layouts.

```typescript
// app/pages/users/index.vue
<script setup lang="ts">
const { data: users, pending, error } = await useFetch('/api/users', {
  default: () => [],
})
</script>
```

Use `$fetch` for imperative calls (form submissions, deletions):

```typescript
async function deleteUser(id: number) {
  await $fetch(`/api/users/${id}`, { method: 'DELETE' })
  await refresh() // from useFetch
}
```

### Custom Composables

Extract reusable logic — composables are the Vue equivalent of React custom hooks.

```typescript
// app/composables/useUsers.ts
export function useUsers() {
  const store = useUserStore()
  const toast = useToast() // PrimeVue toast composable

  async function removeUser(id: number) {
    try {
      await $fetch(`/api/users/${id}`, { method: 'DELETE' })
      store.users = store.users.filter((u) => u.id !== id)
      toast.add({ severity: 'success', summary: 'User deleted', life: 3000 })
    } catch {
      toast.add({ severity: 'error', summary: 'Failed to delete user', life: 5000 })
    }
  }

  return { removeUser }
}
```

