## Testing Standards

### Unit Tests with Vitest

```typescript
// tests/components/UserCard.test.ts
import { mount } from '@vue/test-utils'
import { describe, it, expect } from 'vitest'
import UserCard from '~/app/components/users/UserCard.vue'

describe('UserCard', () => {
  it('renders the user name', () => {
    const wrapper = mount(UserCard, {
      props: { user: { id: 1, name: 'Alice', email: 'alice@test.com' } },
    })
    expect(wrapper.text()).toContain('Alice')
  })

  it('emits select event on click', async () => {
    const user = { id: 1, name: 'Alice', email: 'alice@test.com' }
    const wrapper = mount(UserCard, { props: { user } })

    await wrapper.trigger('click')

    expect(wrapper.emitted('select')?.[0]).toEqual([user])
  })
})
```

### E2E Tests with Playwright

```typescript
// e2e/users.spec.ts
import { test, expect } from '@playwright/test'

test.describe('Users', () => {
  test('shows user list on /users', async ({ page }) => {
    await page.goto('/users')
    await expect(page.getByRole('table')).toBeVisible()
  })

  test('creates a new user', async ({ page }) => {
    await page.goto('/users/new')
    await page.getByLabel('Name').fill('Alice Smith')
    await page.getByLabel('Email').fill('alice@test.com')
    await page.getByRole('button', { name: 'Save' }).click()

    await expect(page).toHaveURL('/users')
    await expect(page.getByText('Alice Smith')).toBeVisible()
  })
})
```

Rules:
- Use `data-testid` attributes for elements with no accessible label
- Test user journeys, not implementation details
- Co-locate E2E tests by feature in `e2e/`
- Test both happy path and error scenarios

