## Infrastructure Layer — Prisma Repositories

```typescript
// server/infrastructure/repositories/PrismaUserRepository.ts
import type { IUserRepository } from '../../domain/repositories/IUserRepository'
import { User } from '../../domain/entities/User'
import { prisma } from '../../utils/prisma'

export class PrismaUserRepository implements IUserRepository {
  async findById(id: number): Promise<User | null> {
    const record = await prisma.user.findUnique({ where: { id } })
    return record ? new User(record) : null
  }

  async create(data: { name: string; email: string }): Promise<User> {
    const record = await prisma.user.create({ data })
    return new User(record)
  }
}
```

Rules:
- Only this layer imports `@prisma/client`
- Always maps Prisma records to domain entities before returning
- Never returns raw Prisma objects up the stack

