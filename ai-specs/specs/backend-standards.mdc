## Application Layer — Services

```typescript
// server/services/userService.ts
import type { IUserRepository } from '../domain/repositories/IUserRepository'
import { PrismaUserRepository } from '../infrastructure/repositories/PrismaUserRepository'

// Singleton factory — swap implementation for testing
let instance: UserService | null = null

export function getUserService(repo?: IUserRepository): UserService {
  if (!instance) instance = new UserService(repo ?? new PrismaUserRepository())
  return instance
}

export class UserService {
  constructor(private readonly repo: IUserRepository) {}

  async findById(id: number) {
    const user = await this.repo.findById(id)
    if (!user) throw new Error('User not found')
    return user
  }

  async create(data: { name: string; email: string }) {
    const existing = await this.repo.findByEmail(data.email)
    if (existing) throw new Error('Email already registered')
    return this.repo.create(data)
  }
}
```

Rules:
- Services never import H3, Prisma, or Valibot directly
- Input is already validated before reaching service (done at API route layer)
- Services throw plain `Error` with descriptive messages — API routes translate to HTTP errors

