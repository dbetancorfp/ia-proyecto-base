## Testing Standards

### Unit Tests with Vitest

```typescript
// tests/services/userService.test.ts
import { describe, it, expect, vi, beforeEach } from 'vitest'
import { UserService } from '~/server/services/userService'
import type { IUserRepository } from '~/server/domain/repositories/IUserRepository'

describe('UserService', () => {
  let service: UserService
  let mockRepo: IUserRepository

  beforeEach(() => {
    mockRepo = {
      findById: vi.fn(),
      findAll: vi.fn(),
      create: vi.fn(),
      update: vi.fn(),
      delete: vi.fn(),
    }
    service = new UserService(mockRepo)
  })

  describe('findById', () => {
    it('returns user when found', async () => {
      const user = { id: 1, name: 'John', email: 'john@test.com', createdAt: new Date() }
      vi.mocked(mockRepo.findById).mockResolvedValue(user as any)

      const result = await service.findById(1)

      expect(result).toEqual(user)
      expect(mockRepo.findById).toHaveBeenCalledWith(1)
    })

    it('throws when user not found', async () => {
      vi.mocked(mockRepo.findById).mockResolvedValue(null)

      await expect(service.findById(999)).rejects.toThrow('User not found')
    })
  })
})
```

### Test Coverage Requirements

- **Threshold**: 90% for branches, functions, lines, and statements
- **Unit tests**: All services and domain entities
- **Integration tests**: API routes via `$fetch` with test database
- **Test naming**: Descriptive sentence format — `'returns user when found'`
- **Pattern**: AAA — Arrange, Act, Assert

```typescript
// vitest.config.ts
import { defineConfig } from 'vitest/config'

export default defineConfig({
  test: {
    environment: 'node',
    coverage: {
      provider: 'v8',
      thresholds: { branches: 90, functions: 90, lines: 90, statements: 90 },
    },
  },
})
```

